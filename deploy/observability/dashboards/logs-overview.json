{
  "title": "Logs Overview",
  "uid": "ztd-logs-overview",
  "tags": ["ztd-capstone", "logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({namespace=~\"observability|dev|staging|prod\", service=~\"$service\"} | json [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error-level Log Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({namespace=~\"observability|dev|staging|prod\", service=~\"$service\"} | json | level=\"error\" [5m]))",
          "legendFormat": "{{service}} errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Live Log Stream",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{namespace=~\"observability|dev|staging|prod\", service=~\"$service\"} | json",
          "refId": "A"
        }
      ]
    }
  ]
}
