{
  "title": "Cluster Health (Platform Nodes)",
  "uid": "ztd-cluster-health",
  "tags": ["ztd-capstone", "cluster", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Platform Node CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "description": "Platform nodegroup is the only place node-exporter runs (nodeSelector: workload=platform) so every series here is already a platform node.",
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Platform Node Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pod Count (observability + app namespaces)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (namespace) (kube_pod_status_phase{namespace=~\"observability|dev|staging|prod\", phase=\"Running\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pod Restarts (last hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (increase(kube_pod_container_status_restarts_total{namespace=~\"observability|dev|staging|prod\"}[1h])) > 0",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pods per Node (platform vs ng-dense)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count by (node) (kube_pod_info{namespace=~\"observability|dev|staging|prod\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
