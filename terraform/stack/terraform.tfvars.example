# Copy to terraform.tfvars and adjust if needed. All values below are the
# documented defaults for the ztd-demo shared cluster / ztd-capstone project.

region      = "ap-south-1"
aws_profile = "infrathrone-new"
project     = "ztd-capstone"
account_id  = "514422154867"

cluster_name = "ztd-demo"
vpc_id       = "vpc-062ffcaf33a87760f"

private_subnet_ids = [
  "subnet-092d8bf0bdba1ede3",
  "subnet-017f49a267f59869b",
  "subnet-09276e71db6d46cc7",
]

public_subnet_ids = [
  "subnet-0c106bdac632ddf35",
  "subnet-08fd75b717c891983",
  "subnet-082e7f345a2574ecb",
]

node_instance_type = "t3.large"
node_desired_size  = 2
node_min_size      = 2
node_max_size      = 3
node_disk_gib      = 30

sonar_instance_type = "t3.medium"
sonar_disk_gib      = 30

sonar_ingress_cidr = "0.0.0.0/0"

# sonar_db_password left unset -> auto-generated via random_password
